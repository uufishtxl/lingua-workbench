{
    "manifest_version": 3,
    "name": "Lingua Workbench Reader",
    "version": "1.0",
    "description": "Send clean article text directly to Lingua Workbench for reading and AI analysis.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "Readability.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}